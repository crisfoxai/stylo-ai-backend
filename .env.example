# Application
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/stylo-ai

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_SA_JSON={"type":"service_account","project_id":"..."}

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_WARDROBE=stylo-wardrobe
R2_BUCKET_TRYON=stylo-tryon
R2_BUCKET_AVATARS=stylo-avatars

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_KEY=your-internal-secret-key

# OpenWeather
OPENWEATHER_API_KEY=your-openweather-api-key

# IAP (optional)
APPLE_SHARED_SECRET=your-apple-shared-secret
GOOGLE_PLAY_SA_JSON={"type":"service_account","project_id":"..."}

# Observability (optional)
SENTRY_DSN_BACKEND=https://your-dsn@sentry.io/project-id
